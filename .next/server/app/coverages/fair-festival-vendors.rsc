14:[["$","section",null,{"className":"pt-24 pb-16 bg-teal-500","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"max-w-3xl","children":[["$","div",null,{"className":"text-teal-200 mb-4 text-sm","children":[["$","$L13",null,{"href":"/coverages","className":"hover:text-white transition-colors","children":"Who We Cover"}]," ","/ ","Fair & Festival Vendor Insurance"]}],["$","h1",null,{"className":"font-heading text-4xl sm:text-5xl font-bold text-white mb-6","children":"Fair & Festival Vendor Insurance"}],["$","p",null,{"className":"text-teal-100 text-xl mb-8","children":"Specialized coverage for county fair, state fair, and music festival vendors — including certificates, additional insured endorsements, and same-day processing."}],["$","div",null,{"className":"flex flex-col sm:flex-row gap-4","children":[["$","$L13",null,{"href":"/quote","className":"inline-block bg-white text-teal-600 hover:bg-teal-50 px-8 py-4 rounded-xl font-bold text-lg transition-colors text-center","children":"Get a Free Quote"}],["$","a",null,{"href":"tel:844-967-5247","className":"inline-flex items-center justify-center space-x-2 border-2 border-white text-white hover:bg-teal-600 px-8 py-4 rounded-xl font-semibold transition-colors","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-phone w-5 h-5","aria-hidden":"true","children":[["$","path","foiqr5",{"d":"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"}],"$undefined"]}],["$","span",null,{"children":"844-967-5247"}]]}]]}]]}]}]}],["$","section",null,{"className":"py-20 bg-white","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"grid lg:grid-cols-3 gap-12","children":[["$","div",null,{"className":"lg:col-span-2","children":[["$","h2",null,{"className":"font-heading text-2xl font-bold text-slate-900 mb-6","children":"Coverage & Protection"}],["$","div",null,{"className":"space-y-4 mb-10","children":[["$","p","0",{"className":"text-slate-600 leading-relaxed","children":"Fair and festival vendors operate in the most concentrated public settings in the retail world — tens of thousands of people walking past your booth over the course of an event. This creates both tremendous business opportunity and meaningful liability exposure. The right insurance program ensures you can participate confidently without worrying about the financial consequences of an incident."}],["$","p","1",{"className":"text-slate-600 leading-relaxed","children":"Every fair and festival you participate in will require proof of general liability insurance with a minimum of $1 million per occurrence. Many will also require you to name the event, fair board, or venue as an Additional Insured on your policy. We process certificate of insurance requests the same day — often within the hour — so you're never held up from submitting a vendor application."}],["$","p","2",{"className":"text-slate-600 leading-relaxed","children":"Food vendors at fairs and festivals need product liability coverage beyond what's included in standard general liability. Fair food — funnel cakes, corn dogs, BBQ, specialty ethnic foods — involves high-temperature cooking, complex preparation, and service to thousands of people per event. The combination of food safety risk and event scale means product liability is essential."}],"$L1e","$L1f"]}],"$L20","$L21","$L22"]}],"$L23"]}]}]}],"$L24"]
1e:["$","p","3",{"className":"text-slate-600 leading-relaxed","children":"Equipment and inventory coverage protects your display fixtures, cooking equipment, merchandise inventory, and supplies against theft, vandalism, and accidental damage during fair and festival events. Fair environments involve equipment being loaded and unloaded repeatedly over a fair's run — this creates both transit risk and setup/breakdown risk that inland marine coverage addresses."}]
1f:["$","p","4",{"className":"text-slate-600 leading-relaxed","children":"Seasonal vendors who participate in multiple fairs and festivals throughout the year benefit from an annual policy rather than event-by-event short-term policies. Annual policies typically offer better rates, simpler administration (one certificate for all events rather than separate policies per event), and continuous coverage between events. We'll help you structure the right program for your event schedule."}]
20:["$","h2",null,{"className":"font-heading text-2xl font-bold text-slate-900 mb-6","children":"State Compliance"}]
21:["$","p",null,{"className":"text-slate-600 leading-relaxed mb-10","children":"State fairs and county fairs are often governed by state agencies or agricultural boards with specific vendor insurance requirements. Requirements differ from state to state — some require the State to be named as Additional Insured, others have specific minimum limits above the industry standard. Always request the event's vendor insurance requirements document before applying."}]
22:[["$","h2",null,{"className":"font-heading text-2xl font-bold text-slate-900 mb-6","children":"Frequently Asked Questions"}],["$","div",null,{"className":"space-y-4","children":[["$","div","0",{"className":"bg-slate-50 rounded-xl p-6","children":[["$","h3",null,{"className":"font-heading font-semibold text-slate-900 mb-2","children":"Do I need separate insurance for each fair I attend?"}],["$","p",null,{"className":"text-slate-600 text-sm leading-relaxed","children":"Not necessarily. An annual general liability policy covers you at all events throughout the year. You'll need to issue certificates (additional insured endorsements) specific to each event, but the underlying policy is one annual program."}]]}],["$","div","1",{"className":"bg-slate-50 rounded-xl p-6","children":[["$","h3",null,{"className":"font-heading font-semibold text-slate-900 mb-2","children":"The fair board is requiring very specific certificate language. Can you handle that?"}],["$","p",null,{"className":"text-slate-600 text-sm leading-relaxed","children":"Yes — we're experienced with fair board certificate requirements, including specific additional insured language, notice of cancellation requirements, and description of operations language. Tell us what the fair board needs and we'll produce it."}]]}],["$","div","2",{"className":"bg-slate-50 rounded-xl p-6","children":[["$","h3",null,{"className":"font-heading font-semibold text-slate-900 mb-2","children":"Do I need insurance for a one-day pop-up market?"}],["$","p",null,{"className":"text-slate-600 text-sm leading-relaxed","children":"If the market or event requires it — yes. Short-term event policies are available for single-day or single-event coverage if you only need coverage occasionally."}]]}],["$","div","3",{"className":"bg-slate-50 rounded-xl p-6","children":[["$","h3",null,{"className":"font-heading font-semibold text-slate-900 mb-2","children":"What if I sell at both indoor and outdoor events?"}],["$","p",null,{"className":"text