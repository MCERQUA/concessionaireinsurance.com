10:["$","$1","c",{"children":[[["$","section",null,{"className":"pt-24 pb-16 bg-teal-500","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center","children":[["$","h1",null,{"className":"font-heading text-4xl sm:text-5xl font-bold text-white mb-6","children":"About Contractors Choice Agency"}],["$","p",null,{"className":"text-teal-100 text-xl max-w-3xl mx-auto","children":"Founded by a former contractor in 2005, we specialize in commercial insurance for specialty trade businesses — including concessionaires and event vendors nationwide."}]]}]}],["$","section",null,{"className":"py-20 bg-white","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"grid lg:grid-cols-2 gap-16 items-start","children":[["$","div",null,{"children":[["$","h2",null,{"className":"font-heading text-3xl font-bold text-slate-900 mb-6","children":"The Josh Cotner Story"}],["$","div",null,{"className":"space-y-5 text-slate-600 leading-relaxed","children":[["$","p",null,{"children":"Josh Cotner didn't start in insurance — he started with his hands in the trade. Working as a contractor in Arizona gave Josh a firsthand understanding of what business owners in the trades and vendor industries actually need from their insurance coverage: clarity, responsiveness, and a specialist who gets it."}],["$","p",null,{"children":"That frustration with generic insurance agents who didn't understand the nuances of specialty commercial operations led Josh to transition into insurance with a clear mission: build an agency that serves specialty businesses with the same expertise and professionalism that those businesses bring to their own trades."}],["$","p",null,{"children":"Contractors Choice Agency was founded in 2005. Over two decades, Josh and his team have built one of the most specialized commercial insurance programs in the Southwest, serving clients across 50+ specialty niches — including an expanding focus on concessionaires and event vendors who face the same challenges that drew Josh to the industry in the first place: mobile operations, multi-state compliance, and insurance agents who don't understand their world."}],["$","p",null,{"children":"Today, Contractors Choice Agency is headquartered in Chandler, Arizona, with additional offices in downtown Phoenix and Miami, Florida. We're licensed in all 50 states and serve clients from food truck operators in California to carnival operators working the state fair circuit from Florida to Washington."}],["$","p",null,{"children":"Our approach is simple: treat every client with the same expertise and attention we'd want if we were in their position. That means fast quotes, same-day certificates, honest coverage recommendations, and a team that answers the phone when you need them."}]]}]]}],["$","div",null,{"children":[["$","div",null,{"className":"rounded-2xl overflow-hidden shadow-xl mb-8","children":["$","img",null,{"src":"/images/team.jpg","alt":"Contractors Choice Agency team","className":"w-full h-80 object-cover"}]}],["$","div",null,{"className":"grid grid-cols-2 gap-4","children":[["$","div","0",{"className":"bg-slate-50 rounded-xl p-4 text-center","children":[["$","div",null,{"className":"flex justify-center mb-2","children":["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-award w-5 h-5 text-teal-500","aria-hidden":"true","children":[["$","path","1yiouv",{"d":"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"}],"$L14","$undefined"]}]}],"$L15","$L16"]}],"$L17","$L18","$L19"]}]]}]]}]}]}],"$L1a","$L1b"],null,"$L1c"]}]
